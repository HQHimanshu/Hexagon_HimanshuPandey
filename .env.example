# App
APP_ENV=development
SECRET_KEY=your_jwt_secret_key_change_in_production
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Database
DATABASE_URL=sqlite+aiosqlite:///./krishidrishti.db

# AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
RAG_COLLECTION_NAME=crop_knowledge_maharashtra

# APIs
OPENWEATHER_API_KEY=your_openweathermap_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Notifications
DEFAULT_LANGUAGE=hi
VOICE_ALERT_ENABLED=true

# Resource Budgets
WATER_BUDGET_LITERS_PER_ACRE=10000
FERTILIZER_BUDGET_GRAMS_PER_ACRE=5000
